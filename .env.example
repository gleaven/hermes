# ───────────────────────────────────────────────────────────────────
# Hermes has no external API dependencies — YOLO11 training and
# inference run locally on your GPU.
# ───────────────────────────────────────────────────────────────────

# Max upload size for training images / videos.
MAX_UPLOAD_MB=200

# ───────────────────────────────────────────────────────────────────
# Host port mappings.
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080
REDIS_HOST_PORT=6379

# ───────────────────────────────────────────────────────────────────
# BYO overrides — uncomment + set + start with the byo override.
#   docker compose -f docker-compose.yml -f docker-compose.byo.yml up -d
# ───────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis.example.com:6379/9

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
